# Application
APP_NAME="AI Travel Planner"
ENV="dev" # test, dev, production
LOG_LEVEL="INFO"
API_PREFIX="/api/v1"

# LLM
OPENAI_API_KEY="sk-..."
LLM_MODEL="gpt-4o"

# Tools
SERPER_API_KEY="serper-..."
WEATHER_API_KEY="weather-..."

# Persistence
# For dev, sqlite is used automatically if ENV=dev. 
# For production, supply a postgres URL:
# DATABASE_URL="postgresql+asyncpg://user:password@host:5432/travel_planner"
